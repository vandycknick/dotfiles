#!/usr/bin/env sh

set -eou pipefail

filter="${1-}"
current="$(kubectl config current-context)"
selected=$(
  kubectl config get-contexts --no-headers=true --output=name | grep "$filter" | \
  gum filter --selected ="$current" --header "Change current kubeconfig context" --select-if-one --no-fuzzy
)

kubectl config use-context "$selected"
